        <type>bool</type>
        <definition>static bool JSL::Event::Antenna::Transmit</definition>
        <argsstring>(std::string_view identifier, std::string_view msg, double timeout=2)</argsstring>
        <name>Transmit</name>
        <qualifiedname>JSL::Event::Antenna::Transmit</qualifiedname>
        <param>
          <type>std::string_view</type>
          <declname>identifier</declname>
        </param>
        <param>
          <type>std::string_view</type>
