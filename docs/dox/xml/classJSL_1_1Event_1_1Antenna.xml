        </param>
        <param>
          <type>double</type>
          <declname>timeout</declname>
          <defval>2</defval>
        </param>
        <briefdescription>
<para>Sends a message to an <ref refid="classJSL_1_1Event_1_1Antenna" kindref="compound">Antenna</ref> with matching identifier. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>identifier</parametername>
</parameternamelist>
<parameterdescription>
<para>The name of the <ref refid="classJSL_1_1Event_1_1Antenna" kindref="compound">Antenna</ref> which is being reached. If no matching antenna (or external process) is found, an error is thrown </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>msg</parametername>
</parameternamelist>
<parameterdescription>
<para>The message to be communicated </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>timeout</parametername>
</parameternamelist>
<parameterdescription>
<para>The time to wait for an acknowledgement from the reciever that the message was returned. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>True if the message was acknowledged, false otherwise </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
